# 忽略所有 .env 文件 (通常包含环境变量和密钥)
.env
.env.local
.env.production

# 忽略所有 pem 或 key 后缀的证书文件
*.pem
*.key

# 忽略压缩文件
*.zip
*.rar
*.tar.gz
*.7z

# 忽略 IDE 或系统产生的临时文件
.DS_Store
*.log

analysis/
design/
.vscode/
/.pytest_cache/
**/.pytest_cache/
__pycache__/
**/__pycache__/

/.dist/
**/.dist/

# 忽略所有 .pyc 文件 (Python 编译文件)
*.pyc
