server:
  host: 127.0.0.1
  port: 8000

app:
  demo: false

logicfp:
  instance_id: openclaw-node-a
  default_source: api
  backend_type: memory
  handler_registrars:
    - examples.openclaw.register_handlers

openclaw:
  gateway_url: ws://127.0.0.1:18789
  agent_id: main
  main_key: main
  session_prefix: agent
  channel: acp
  remote_token_env: OPENCLAW_GATEWAY_TOKEN
