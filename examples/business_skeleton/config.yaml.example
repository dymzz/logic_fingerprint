server:
  host: 127.0.0.1
  port: 8000

app:
  demo: false

logic_fingerprint:
  instance_id: business-node-a
  default_source: api
  backend_type: memory
  handler_registrars:
    - examples.business_skeleton.handlers.register

business:
  inventory_source: inventory-db
  pricing_currency: CNY
  stock_offset: 0
  default_discount_rate: 0.05
